<div class="container mt-5">
    <div class="row">
        <div class="col-md-4 mx-auto">
            <div class="logo mx-auto">
                <img src="{{ logo_img }}" class="img-thumbnail mx-auto d-block mt-5 logo_avatar" alt="">
            </div>
            <form action="users/login" method="post">
                <div class="form-group mt-4 login-form">
                    <input type="text" name="username" id="username" class="form-control" placeholder="username">
                </div>
                <div class="form-group mt-4 login-form">
                    <input type="password" name="password" id="password" class="form-control" placeholder="password">
                 </div>
                <div class="d-grid form-group mt-3">
                    <button type="submit" class="btn btn-success">
                        Login
                    </button>
                </div>
                <div class="d-grid mt-4">
                    <a href="/users/register/" class="btn btn-outline-primary">Register</a>
                </div>
            </form>
        </div>
    </div>
</div>