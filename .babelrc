{
    "presets": [
        [
            "@babel/preset-env",
            {
                "targets": { "node": "current" },
                "useBuiltIns": "usage",
                "corejs": 3
            }
        ]
    ],
    "plugins": [
        ["@babel/plugin-proposal-class-properties", { "loose": true }],
        ["@babel/plugin-transform-runtime", { "regenerator": true }]
    ]
}